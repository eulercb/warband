# Warband — optional connectivity config.
#
# Copy to `.env.local` (git-ignored) and fill in to override the defaults.
# All vars are read at BUILD time (Vite `import.meta.env`), so rebuild after
# changing them. None are required — Warband ships working defaults.
#
# See docs/NETWORKING.md for the full explanation of how peers connect.

# --- TURN relay (for reliable play across the internet) ------------------------
# WebRTC needs a TURN relay whenever two players can't reach each other directly
# (symmetric NATs, mobile carriers, corporate/campus firewalls). Warband bundles
# a free best-effort public relay, but for dependable play point these at your
# own TURN server (self-hosted coturn, or a metered.ca / Twilio / Cloudflare
# account). One or more comma-separated URLs.
# VITE_TURN_URL=turn:your-turn-host:3478,turns:your-turn-host:5349
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-credential

# Set truthy to drop the bundled public TURN and use ONLY your VITE_TURN_URL.
# VITE_NO_DEFAULT_TURN=false

# --- Same-machine loopback (two tabs / two windows) ----------------------------
# For privacy, browsers hide local-IP host candidates behind randomized `*.local`
# mDNS hostnames. Resolving those needs an mDNS responder that is often blocked
# (corporate security software, privacy extensions, separate browser profiles),
# and when it is even TWO TABS ON ONE MACHINE fail to connect after exchanging
# SDP. Warband works around this by rewriting `*.local` host candidates to
# 127.0.0.1 so same-machine peers connect directly over loopback — no mDNS, no
# TURN. This is ON by default and does not affect play between different machines
# (their STUN/TURN candidates are untouched). Set truthy ONLY if you specifically
# want two DIFFERENT machines on the same LAN to prefer a direct local link.
# VITE_NO_RTC_LOOPBACK=false

# --- Global server (guaranteed-connectivity relay) -----------------------------
# WebSocket URL of a Warband relay (see server/relay.mjs — `npm run relay` runs
# one on :8787). When set, the Host and Join screens offer a "global server"
# connection mode that routes ALL game traffic through this machine instead of
# forming WebRTC peer connections. It is the fallback of last resort for
# networks where even TURN can't punch through: if the players can open a plain
# outbound WebSocket, they can play. Use wss:// (TLS) in production — browsers
# on HTTPS pages refuse plain ws://.
# VITE_RELAY_URL=wss://relay.example.com

# --- Trackers (signaling / peer matchmaking) -----------------------------------
# Extra WebTorrent tracker URLs (comma or whitespace separated) added to the
# built-in pool. More trackers = better odds two peers find each other if some
# are down. Must be `wss://` WebSocket trackers.
# VITE_TRACKER_URLS=wss://tracker.example.com,wss://tracker2.example.com

# --- Verbose networking logs (debugging connections) ---------------------------
# Set truthy to bake verbose connection logging into the build: room joins,
# tracker sockets, peer handshakes, and every lobby message, all prefixed
# `[warband:net]`. It is already ON automatically under `npm run dev`, so you
# only need this to debug a *production* build. You can also flip it on at
# runtime with no rebuild: open the browser console and run
# `warband.netDebug(true)` (then reload), or `warband.diagnose()` for a one-shot
# connectivity snapshot. See docs/NETWORKING.md → "Debugging with verbose logs".
# VITE_NET_DEBUG=true
